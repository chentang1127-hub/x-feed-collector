# === X/Twitter 账号 Cookie ===
# 在浏览器登录 X 后，F12 → Application → Cookies → https://x.com
X_AUTH_TOKEN=your_auth_token_here
X_CT0=your_ct0_value_here

# === 飞书应用凭证 ===
# 去 https://open.feishu.cn 创建应用 → 开通机器人能力 → 发布
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_hook_here

# === 采集目标 ===
TARGET_USERNAME=Serenity
